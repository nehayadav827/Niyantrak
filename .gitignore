# ============================================================
# ML model artifacts
# Keep models out of Git unless needed for demo submission
# ============================================================
models/*.pkl
models/*.joblib
models/*.cbm
models/*.model

# If you want to keep empty models folder
!models/.gitkeep

# ============================================================
# Dataset files
# Usually do not push raw datasets
# ============================================================
data/*.csv
data/*.xlsx
data/*.xls
data/*.parquet
data/*.json

# If you want to keep empty data folder
!data/.gitkeep

